# 复制为 .env 后填入真实 key
KIMI_KEY=your-kimi-api-key
KIMI_CODE_KEY=your-kimi-code-api-key
DEEPSEEK_KEY=your-deepseek-api-key

# 可选：自定义 base URL
# KIMI_BASE=https://api.moonshot.cn/v1
# KIMI_CODE_BASE=https://api.moonshot.cn/v1
# DEEPSEEK_BASE=https://api.deepseek.com/v1

# 可选：模型名称
# KIMI_MODEL=moonshot-v1-8k
# KIMI_CODE_MODEL=moonshot-v1-8k
# DEEPSEEK_MODEL=deepseek-chat

# 可选：流水线模式
# full  = Planner -> Coder -> Critic -> Validator -> Repairer（质量最高）
# fast  = Coder(DeepSeek) -> Repairer(DeepSeek)（速度与质量平衡）
# ultra = DeepSeek 单模型强输出（最快）
# PIPELINE_MODE=full

# 可选：附件文件截断长度（默认 0，表示不截断，适合 DeepSeek 大上下文）
# MAX_ATTACH_CHARS=0

# 可选：智能附件路由（默认 auto）
# 开启后 Kimi 只看文件路径，DeepSeek 看完整内容，避免 Kimi 8k 爆上下文
# SMART_ATTACH=1

# 可选：模型安全上下文限制（token 数）
# KIMI_CONTEXT_LIMIT=6000
# DS_CONTEXT_LIMIT=100000

# 可选：API 失败重试次数（默认 2）
# API_MAX_RETRIES=2

# 可选：API 超时时间秒数（默认 300）
# API_TIMEOUT=300

# 可选：输出目录（默认 outputs）
# OUTPUT_DIR=outputs

# 可选：开启调试日志
# PIPELINE_DEBUG=1
