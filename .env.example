# 复制为 .env 后填入真实 key
KIMI_KEY=your-kimi-api-key
KIMI_CODE_KEY=your-kimi-code-api-key
DEEPSEEK_KEY=your-deepseek-api-key

# 可选：自定义 base URL
# KIMI_BASE=https://api.moonshot.cn/v1
# KIMI_CODE_BASE=https://api.moonshot.cn/v1
# DEEPSEEK_BASE=https://api.deepseek.com/v1

# 可选：模型名称
# KIMI_MODEL=moonshot-v1-8k
# KIMI_CODE_MODEL=moonshot-v1-8k
# DEEPSEEK_MODEL=deepseek-chat

# 可选：附件文件截断长度（默认 4000）
# 设置为 0 表示不截断，适合 DeepSeek 等大上下文模型
# MAX_ATTACH_CHARS=0
